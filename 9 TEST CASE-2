import pandas as pd
import statsmodels.api as sm
from statsmodels.formula.api import ols

# Data: Advertising spend vs. Sales units
data = {
    "Ad_Spend": [10, 20, 30, 40, 50, 60, 70, 80],
    "Sales": [15, 25, 28, 45, 48, 62, 65, 82]
}

df = pd.DataFrame(data)

# Simple Linear Regression model
# 'Sales ~ Ad_Spend' means Sales is the dependent variable (y)
model = ols('Sales ~ Ad_Spend', data=df).fit()

print("Model Summary:")
print(model.summary().tables[1]) # Displaying the coefficients table

print(f"\nR-squared: {model.rsquared:.4f}")

